# ===== فيسبوك =====
# من Meta Developer Console > صفحتك > Page Access Token
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here

# كلمة سر الـ Webhook (اكتب أي كلمة وضعها في الإعدادات كمان)
FB_VERIFY_TOKEN=tanta_real_estate_2026

# App Secret من Meta Developer Console
FB_APP_SECRET=your_app_secret_here

# ===== واتساب (360dialog) =====
# من حسابك على app.360dialog.com
WHATSAPP_API_KEY=your_360dialog_api_key_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ===== إعدادات عامة =====
PORT=5000
DEBUG=false
